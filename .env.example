########################################
# Newspaper 프로젝트 환경 변수 예시
# .env.example을 복사하여 .env 생성 후 값 입력
########################################

# --- DB ---
DB_URL=jdbc:mysql://localhost:3306/newspaper?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=root
DB_PASSWORD=root

# --- Naver Mail IMAP ---
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_HOST=imap.naver.com
MAIL_PORT=993

# --- MinIO(S3) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=newspaper-bucket
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_REGION=us-east-1

# --- Gemini AI ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_ENABLED=true

# --- CORS (배포 시 프론트엔드 도메인, 쉼표 구분) ---
# 예: https://newspaper.example.com,https://dailyfocus.example.com
# CORS_ALLOWED_ORIGINS=
